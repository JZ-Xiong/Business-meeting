<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- Remote Video (full screen background) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteVideoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/chatContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Remote placeholder when no video -->
    <TextView
        android:id="@+id/tvRemotePlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for others to join…"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/remoteVideoView"
        app:layout_constraintBottom_toBottomOf="@id/remoteVideoView"
        app:layout_constraintStart_toStartOf="@id/remoteVideoView"
        app:layout_constraintEnd_toEndOf="@id/remoteVideoView" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Connection indicator -->
        <View
            android:id="@+id/viewConnectionDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/success" />

        <TextView
            android:id="@+id/tvRoomInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="room-1"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvParticipantCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 participant"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Local Video (PiP - bottom right) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localVideoView"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Label on local video -->
    <TextView
        android:id="@+id/tvLocalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_local_video"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:background="#66000000"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="@id/localVideoView"
        app:layout_constraintStart_toStartOf="@id/localVideoView" />

    <!-- Chat Container (collapsible bottom section) -->
    <LinearLayout
        android:id="@+id/chatContainer"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="@color/surface_card"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Chat header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@color/surface_input">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chat"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseChat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close chat"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <!-- Chat messages list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp"
            android:clipToPadding="false" />

        <!-- Chat input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@color/surface_input">

            <EditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="@string/hint_chat_message"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="13sp"
                android:background="@color/surface_card"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:inputType="text" />

            <ImageButton
                android:id="@+id/btnSendChat"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@color/primary"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Send"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Control Bar (bottom) -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/surface_card"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mic toggle -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/btn_control_bg"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Toggle microphone"
            app:tint="@color/white" />

        <!-- Camera toggle -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/btn_control_bg"
            android:src="@android:drawable/ic_menu_camera"
            android:contentDescription="Toggle camera"
            app:tint="@color/white" />

        <!-- Chat toggle -->
        <ImageButton
            android:id="@+id/btnChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/btn_control_bg"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="Toggle chat"
            app:tint="@color/white" />

        <!-- Hang up -->
        <ImageButton
            android:id="@+id/btnHangUp"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/btn_hangup_bg"
            android:src="@android:drawable/ic_menu_call"
            android:contentDescription="Hang up"
            app:tint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
